# LiteRAG 环境变量配置
# 复制此文件为 .env.local 并修改配置

# 模型调用模式：local（Ollama）/ lmstudio（LM Studio）/ remote（远程 API）
MODEL_SOURCE=remote

# === 远程 API 配置（MODEL_SOURCE=remote 时必填）===
# OpenAI 兼容 API 地址
OPENAI_BASE_URL=https://api.openai.com/v1
# API 密钥
OPENAI_API_KEY=sk-your-api-key-here
# Embedding 模型名称（1536 维）
EMBEDDING_MODEL=text-embedding-ada-002
# Rerank 模型名称（通过 Chat API 评分，可选）
RERANK_MODEL=gpt-4o-mini

# === Ollama 本地模型配置（MODEL_SOURCE=local 时必填）===
# Ollama 服务地址
OLLAMA_HOST=http://localhost:11434
# 本地 Embedding 模型
OLLAMA_EMBEDDING_MODEL=bge-large:latest
# 本地 Rerank 模型（通过 Chat API 评分，可选）
OLLAMA_RERANK_MODEL=

# === LM Studio 本地模型配置（MODEL_SOURCE=lmstudio 时必填）===
# LM Studio 提供 OpenAI 兼容 API (默认端口 1234)
# LM Studio 服务地址（末尾必须含 /v1）
LMSTUDIO_HOST=http://localhost:1234/v1
# Embedding 模型（取决于 LM Studio 中加载的模型）
LMSTUDIO_EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5
# Rerank 模型（通过 Chat API 评分，可选；取决于 LM Studio 中加载的模型）
LMSTUDIO_RERANK_MODEL=

# === 数据库配置 ===
# SQLite 数据库文件路径（相对于项目根目录）
DATABASE_PATH=./data/literag.db

# === RAG 检索配置 ===
# 默认返回结果数
DEFAULT_TOP_K=5
# 是否默认启用混合检索
DEFAULT_HYBRID_SEARCH=true
# 是否默认启用 Rerank
DEFAULT_RERANK=true
# 文档分块大小（字符数）
CHUNK_SIZE=512
# 文档分块重叠（字符数）
CHUNK_OVERLAP=128
